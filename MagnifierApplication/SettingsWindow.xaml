<Window x:Class="MagnifierApplication.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MagnifierApplication"
        mc:Ignorable="d"
        Title="Magnifier Settings" Height="600" Width="500">
    
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="20">
        
            <TextBlock Text="Profile"
           FontWeight="Bold"
           FontSize="14"
           Margin="0,0,0,8"/>

            <TextBlock Text="Circle / Square" Margin="0,15,0,0"/>
            <ComboBox Name="ProfileComboBox"
              SelectedIndex="0">
                <ComboBoxItem Content="Default" />
                <ComboBoxItem Content="Profile1" />
                <ComboBoxItem Content="Profile2" />
                <ComboBoxItem Content="Profile3" />
                <ComboBoxItem Content="Profile4" />
            </ComboBox>
        
            <TextBlock Text="Appearance"
                   FontWeight="Bold"
                   FontSize="14"
                   Margin="0,15,0,8"/>

        <TextBlock Text="Circle / Square" Margin="0,15,0,0"/>
        <ComboBox Name="ShapeComboBox"
                      SelectedIndex="0">
            <ComboBoxItem Content="Circle" />
            <ComboBoxItem Content="Square" />
        </ComboBox>
        
        <Grid Margin="0,15,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Lens Size"/>
                <TextBlock Name="LensSizeValueText"
                           Grid.Column="1"
                           Text="200px" />
            </Grid>
            <Slider Name="LensSizeSlider"
                    Minimum="100"
                    Maximum="400"
                    TickFrequency="10"
                    IsSnapToTickEnabled="True" />

        <Grid Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Border Thickness"/>
            <TextBlock Name="BorderThicknessValueText" Grid.Column="1" Text="3px"/>
        </Grid>
        <Slider Name="BorderThicknessSlider"
                    Minimum="0"
                    Maximum="10"
                    TickFrequency="1"
                    IsSnapToTickEnabled="True"/>



        
        <TextBlock Text="Magnification"
                   FontWeight="Bold"
                   FontSize="14"
                   Margin="0,25,0,8"/>

        <Grid Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="Magnification"/>
            <TextBlock Name="MagnificationValueText"
                           Grid.Column="1"
                           Text="2.0x" />
        </Grid>
        <Slider Name="MagnificationSlider"
                    Minimum="1"
                    Maximum="6"
                    TickFrequency="0.5"
                    IsSnapToTickEnabled="True"
                    AutoToolTipPlacement="TopLeft"
                    AutoToolTipPrecision="1"
                    IsMoveToPointEnabled="True"/>


        <TextBlock Text="Position"
           FontWeight="Bold"
           FontSize="14"
           Margin="0,25,0,8"/>

        <Grid Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Lens Offset X"/>
            <TextBlock Name="WindowOffsetXValueText" Grid.Column="1" Text="140px"/>
        </Grid>
        <Slider Name="WindowOffsetXSlider"
                    Minimum="-300"
                    Maximum="300"/>

        <Grid Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Lens Offset Y"/>
            <TextBlock Name="WindowOffsetYValueText" Grid.Column="1" Text="40px"/>
        </Grid>
        <Slider Name="WindowOffsetYSlider"
                    Minimum="-300"
                    Maximum="300"/>

        <TextBlock Text="Capture"
           FontWeight="Bold"
           FontSize="14"
           Margin="0,25,0,8"/>

        <TextBlock Text="Capture Source Preset" />
        <ComboBox Name="CapturePresetComboBox"
                      Margin="0,4,0,8">
            <ComboBoxItem Content="Centered on Cursor"/>
            <ComboBoxItem Content="Above Cursor"/>
            <ComboBoxItem Content="Below Cursor"/>
            <ComboBoxItem Content="Left of Cursor"/>
            <ComboBoxItem Content="Right of Cursor"/>
            <ComboBoxItem Content="Custom"/>
        </ComboBox>

        <Grid Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Capture Offset X"/>
            <TextBlock Name="CaptureOffsetXValueText" Grid.Column="1" Text="-50px"/>
        </Grid>
        <Slider Name="CaptureOffsetXSlider"
                    Minimum="-300"
                    Maximum="300"/>

        <Grid Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Capture Offset Y"/>
            <TextBlock Name="CaptureOffsetYValueText" Grid.Column="1" Text="-50px"/>
        </Grid>
        <Slider Name="CaptureOffsetYSlider"
                    Minimum="-300"
                    Maximum="300"/>

    </StackPanel>
    </ScrollViewer>
</Window>
