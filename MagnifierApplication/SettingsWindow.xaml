<Window x:Class="MagnifierApplication.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MagnifierApplication"
        mc:Ignorable="d"
        Title="Magnifier Settings"
        Height="720"
        Width="900"
        Background="#DCE6F2">

    <Window.Resources>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1F2933"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1D4ED8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ValuePill" TargetType="TextBlock">
            <Setter Property="Background" Value="#EFF6FF"/>
            <Setter Property="Foreground" Value="#1D4ED8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="MinWidth" Value="54"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#FCFCFD"/>
            <Setter Property="BorderBrush" Value="#D9DEE5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,4,0,12"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,4,0,10"/>
            <Setter Property="Padding" Value="7,3"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="12,0"/>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,4,0,14"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,8,0,4"/>
            <Setter Property="Foreground" Value="#1F2933"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT COLUMN -->
            <StackPanel Grid.Column="0">

                <!-- Profile -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Background="#2563EB" CornerRadius="2"/>
                            <TextBlock Grid.Column="2"
                                       Text="Profile"
                                       Style="{StaticResource SectionTitle}"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox Name="ProfileComboBox"
                                      SelectedIndex="0"
                                      Margin="0,0,12,0">
                                <ComboBoxItem Content="Default"/>
                                <ComboBoxItem Content="Profile 1"/>
                                <ComboBoxItem Content="Profile 2"/>
                                <ComboBoxItem Content="Profile 3"/>
                                <ComboBoxItem Content="Profile 4"/>
                            </ComboBox>

                            <Button Name="RenameProfileButton"
                                    Grid.Column="1"
                                    Content="Rename"
                                    Width="90"/>
                        </Grid>

                        <StackPanel Name="RenameProfilePanel"
                                    Visibility="Collapsed"
                                    Margin="0,14,0,0">
                            <TextBlock Text="New Profile Name"/>
                            <TextBox Name="ProfileNameTextBox"/>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <Button Name="SaveProfileNameButton"
                                        Content="Save"
                                        Width="75"
                                        Margin="0,0,8,0"/>

                                <Button Name="CancelProfileNameButton"
                                        Content="Cancel"
                                        Width="75"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Appearance -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Background="#2563EB" CornerRadius="2"/>
                            <TextBlock Grid.Column="2"
                                       Text="Appearance"
                                       Style="{StaticResource SectionTitle}"/>
                        </Grid>

                        <TextBlock Text="Rendering Mode"/>
                        <ComboBox Name="SharpnessComboBox" SelectedIndex="0">
                            <ComboBoxItem Content="Sharp"/>
                            <ComboBoxItem Content="Smooth"/>
                        </ComboBox>

                        <TextBlock Text="Lens Shape"/>
                        <ComboBox Name="ShapeComboBox" SelectedIndex="0">
                            <ComboBoxItem Content="Circle"/>
                            <ComboBoxItem Content="Square"/>
                        </ComboBox>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Lens Size"/>
                            <TextBlock Name="LensSizeValueText"
                                       Grid.Column="1"
                                       Text="200px"
                                       Style="{StaticResource ValuePill}"/>
                        </Grid>

                        <Slider Name="LensSizeSlider"
                                Minimum="100"
                                Maximum="400"
                                TickFrequency="10"
                                IsSnapToTickEnabled="True"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Border Thickness"/>
                            <TextBlock Name="BorderThicknessValueText"
                                       Grid.Column="1"
                                       Text="3px"
                                       Style="{StaticResource ValuePill}"/>
                        </Grid>

                        <Slider Name="BorderThicknessSlider"
                                Minimum="0"
                                Maximum="10"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"/>
                    </StackPanel>
                </Border>

                <!-- General -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Background="#2563EB" CornerRadius="2"/>
                            <TextBlock Grid.Column="2"
                                       Text="General"
                                       Style="{StaticResource SectionTitle}"/>
                        </Grid>

                        <CheckBox Name="StartWithWindowsCheckBox"
                                  Content="Start with Windows"/>

                        <CheckBox Name="MinimizeToTrayCheckBox"
                                  Content="Minimize to tray when closed"/>

                        <CheckBox Name="StartHiddenCheckBox"
                                  Content="Start hidden"/>
                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- RIGHT COLUMN -->
            <StackPanel Grid.Column="2">

                <!-- Magnification -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Background="#2563EB" CornerRadius="2"/>
                            <TextBlock Grid.Column="2"
                                       Text="Magnification"
                                       Style="{StaticResource SectionTitle}"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Magnification Level"/>
                            <TextBlock Name="MagnificationValueText"
                                       Grid.Column="1"
                                       Text="2.0x"
                                       Style="{StaticResource ValuePill}"/>
                        </Grid>

                        <Slider Name="MagnificationSlider"
                                Minimum="1"
                                Maximum="6"
                                TickFrequency="0.5"
                                IsSnapToTickEnabled="True"
                                AutoToolTipPlacement="TopLeft"
                                AutoToolTipPrecision="1"/>
                    </StackPanel>
                </Border>

                <!-- Position -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Background="#2563EB" CornerRadius="2"/>
                            <TextBlock Grid.Column="2"
                                       Text="Position"
                                       Style="{StaticResource SectionTitle}"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Lens Offset X"/>
                            <TextBlock Name="WindowOffsetXValueText"
                                       Grid.Column="1"
                                       Text="140px"
                                       Style="{StaticResource ValuePill}"/>
                        </Grid>

                        <Slider Name="WindowOffsetXSlider"
                                Minimum="-300"
                                Maximum="300"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Lens Offset Y"/>
                            <TextBlock Name="WindowOffsetYValueText"
                                       Grid.Column="1"
                                       Text="40px"
                                       Style="{StaticResource ValuePill}"/>
                        </Grid>

                        <Slider Name="WindowOffsetYSlider"
                                Minimum="-300"
                                Maximum="300"/>
                    </StackPanel>
                </Border>

                <!-- Capture -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Background="#2563EB" CornerRadius="2"/>
                            <TextBlock Grid.Column="2"
                                       Text="Capture"
                                       Style="{StaticResource SectionTitle}"/>
                        </Grid>

                        <TextBlock Text="Capture Source Preset"/>
                        <ComboBox Name="CapturePresetComboBox">
                            <ComboBoxItem Content="Centered on Cursor"/>
                            <ComboBoxItem Content="Above Cursor"/>
                            <ComboBoxItem Content="Below Cursor"/>
                            <ComboBoxItem Content="Left of Cursor"/>
                            <ComboBoxItem Content="Right of Cursor"/>
                            <ComboBoxItem Content="Custom"/>
                        </ComboBox>

                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Capture Offset X"/>
                            <TextBlock Name="CaptureOffsetXValueText"
                                       Grid.Column="1"
                                       Text="-50px"
                                       Style="{StaticResource ValuePill}"/>
                        </Grid>

                        <Slider Name="CaptureOffsetXSlider"
                                Minimum="-300"
                                Maximum="300"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Capture Offset Y"/>
                            <TextBlock Name="CaptureOffsetYValueText"
                                       Grid.Column="1"
                                       Text="-50px"
                                       Style="{StaticResource ValuePill}"/>
                        </Grid>

                        <Slider Name="CaptureOffsetYSlider"
                                Minimum="-300"
                                Maximum="300"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>